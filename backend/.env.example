PORT=5000
MONGO_URI=mongodb://localhost:27017/straypaws
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Cloudinary — get these from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email — use Gmail with an App Password (not your real password)
# Go to: Google Account → Security → 2FA → App Passwords → create one
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=StrayPaws <your_gmail@gmail.com>
